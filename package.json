{
  "name": "nest-typescript-starter",
  "private": true,
  "version": "1.0.0",
  "description": "Nest TypeScript starter repository",
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:users": "SERVICE_TYPE=users nest start",
    "start:counselings": "SERVICE_TYPE=counselings nest start",
    "start:users:dev": "SERVICE_TYPE=users nest start --watch",
    "start:counselings:dev": "SERVICE_TYPE=counselings nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/jest/bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js --d ./src/common/system/persistences/typeorm-config.ts",
    "migration": "node migration-generate.cjs",
    "migration:run": "yarn typeorm migration:run",
    "migration:revert": "yarn typeorm migration:revert"
  },
  "engines": {
    "npm": ">=8.0.0",
    "node": ">=16.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.632.0",
    "@aws-sdk/s3-request-presigner": "3.632.0",
    "@bufbuild/protobuf": "2.2.1",
    "@google-cloud/storage": "7.16.0",
    "@grpc/grpc-js": "1.12.2",
    "@grpc/proto-loader": "0.7.13",
    "@grpc/reflection": "1.0.4",
    "@langchain/community": "0.3.53",
    "@langchain/core": "0.3.72",
    "@langchain/openai": "0.6.9",
    "@nestjs/common": "11.1.6",
    "@nestjs/config": "4.0.2",
    "@nestjs/core": "11.1.6",
    "@nestjs/microservices": "11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/typeorm": "11.0.0",
    "@sapphire/snowflake": "3.5.5",
    "@types/uuid": "9.0.1",
    "dayjs": "1.11.12",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-prettier": "5.4.0",
    "jest-date-mock": "1.0.10",
    "jest-mock-extended": "3.0.7",
    "kafkajs": "2.2.4",
    "langchain": "0.3.27",
    "pg": "8.13.1",
    "prettier": "3.5.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "typeorm": "0.3.26",
    "typeorm-transactional": "0.5.0",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "@faker-js/faker": "8.4.1",
    "@nestjs/cli": "11.0.10",
    "@nestjs/schematics": "11.0.7",
    "@nestjs/testing": "11.1.6",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.12",
    "@types/node": "20.14.15",
    "@types/supertest": "6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "eslint": "^8.57.1",
    "eslint-plugin-module-resolver": "^1.5.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jest": "29.7.0",
    "source-map-support": "0.5.21",
    "supertest": "7.0.0",
    "ts-jest": "29.2.4",
    "ts-loader": "9.5.1",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coveragePathIgnorePatterns": [
      ".module.ts",
      ".constants.ts",
      "src/main.ts",
      "src/shared/filters/*"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "~users/(.*)$": "<rootDir>/../src/services/users/$1",
      "~counselings/(.*)$": "<rootDir>/../src/services/counselings/$1",
      "~shared/(.*)$": "<rootDir>/../src/shared/$1",
      "~common/(.*)$": "<rootDir>/../src/common/$1",
      "~proto/(.*)$": "<rootDir>/../src/gen/$1",
      "^~/(.*)$": "<rootDir>/../$1"
    }
  },
  "moduleNameMapper": {
    "~users/(.*)$": "<rootDir>/../src/services/users/$1",
    "~counselings/(.*)$": "<rootDir>/../src/services/counselings/$1",
    "~shared/(.*)$": "<rootDir>/../src/shared/$1",
    "~common/(.*)$": "<rootDir>/../src/common/$1",
    "~proto/(.*)$": "<rootDir>/../src/gen/$1",
    "^~/(.*)$": "<rootDir>/../$1"
  }
}
